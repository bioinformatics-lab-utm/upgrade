// nextflow.config

params {
    // Input/Output
    input_dir = "test_data/ont_data"
    outdir = "results"
    
    // Resources
    threads = 128  // Match your available CPU cores
    memory = '100.GB'
    
    // Filtlong parameters - more aggressive for faster processing
    filtlong_min_length = 1500      
    filtlong_keep_percent = 60       // Keep 60% instead of 90%
    filtlong_min_quality = 11
    
    // Assembly parameters - optimized for large metagenomics data
    params.flye_mode = '--nano-raw'
    params.flye_genome_size = '200m'  // Much smaller genome size for memory efficiency
    params.flye_iterations = 1
    params.flye_meta = true
    
    // MetaBAT2 parameters
    metabat2_min_contig = 2500      // Minimum contig length for binning
    metabat2_min_bin = 200000       // Minimum bin size
    
    // CONCOCT parameters
    concoct_min_contig = 1000       // Minimum contig length for binning
    concoct_chunk_size = 10000      // Chunk size for cutting contigs
    concoct_overlap_size = 0        // Overlap size for chunks
    
    // CheckM parameters
    checkm_extension = 'fa'         // File extension for bin files
    
    // Kraken2 parameters
    kraken2_db = '/kraken2_db'       // Path to Kraken2 database (mounted in Docker)
    
    // Bracken parameters
    bracken_read_length = 150        // Read length for Bracken database
    bracken_level = 'S'              // Taxonomic level (S = species)
    bracken_threshold = 1            // Minimum number of reads for classification
    
    // Help parameter
    help = false
}

// Executor configuration for performance
executor {
    name = 'local'
    cpus = 128  // Use all available CPU cores
    memory = '125 GB'  // Increased to use most available system memory
    queueSize = 8
}

// Process configuration
process {
    // Default settings
    cpus = { params.threads }
    memory = { params.memory }
    time = '50h'
    
    // Global retry strategy - CONTINUE logging during retries
    errorStrategy = 'retry'
    maxRetries = 3
    
    // Enable process parallelization
    maxForks = 4
    executor = 'local'
    
    // NanoPlot process
    withName: 'NANOPLOT' {
        cpus = 32  // Increased for 128-core system
        memory = '32.GB'
        time = '6h'
        publishDir = [
            path: "${params.outdir}/01_QC/nanoplot",
            mode: 'copy'
        ]
    }
    
    // Filtlong process
    withName: 'FILTLONG' {
        cpus = 64  // Increased for better performance
        memory = '64.GB'
        time = '4h'
        publishDir = [
            path: "${params.outdir}/02_filtered",
            mode: 'copy'
        ]
    }
    
    // Flye assembly process
    withName: 'FLYE' {
        cpus = 120  // Use most cores for assembly (most CPU-intensive)
        memory = '120.GB'  // Increased memory for large datasets
        time = '120h'
        publishDir = [
            path: "${params.outdir}/03_assembly",
            mode: 'copy'
        ]
    }
    
    // MetaBAT2 binning process
    withName: 'METABAT2' {
        cpus = 64  // Increased for better performance
        memory = '100.GB'
        time = '120h'
        publishDir = [
            path: "${params.outdir}/04_binning/metabat2",
            mode: 'copy'
        ]
    }
    
    // CONCOCT binning process
    withName: 'CONCOCT' {
        cpus = 64  // Increased for better performance
        memory = '100.GB'
        time = '10h'
        publishDir = [
            path: "${params.outdir}/04_binning/concoct",
            mode: 'copy'
        ]
    }
    
    // CheckM quality assessment process
    withName: 'CHECKM.*' {
        cpus = 120  // Increased for faster quality assessment
        memory = '100.GB'
        time = '10h'
        publishDir = [
            path: "${params.outdir}/05_quality",
            mode: 'copy'
        ]
    }
    
    // Kraken2 taxonomic classification process
    withName: 'KRAKEN2.*' {
        cpus = 128  // Use all available cores for maximum speed
        memory = '100.GB'  // Increased memory allocation
        time = '240h'  // Extended time limit to 10 days for long Kraken2 runs
        errorStrategy = 'retry'  // CONTINUE logging during retries - nu se oprește .nextflow.log
        maxRetries = 3
        publishDir = [
            path: "${params.outdir}/06_kraken2",
            mode: 'copy',
            enabled: true,  // Force publish even after retries/timeouts
            saveAs: { filename -> 
                // Always save results regardless of task exit status
                return filename
            }
        ]
    }
    
    // Bracken species-level abundance estimation process
    withName: 'BRACKEN.*' {
        cpus = 128   // Sufficient cores for Bracken processing
        memory = '100.GB'
        time = '24h'
        errorStrategy = 'retry'
        maxRetries = 3
        publishDir = [
            path: "${params.outdir}/07_bracken",
            mode: 'copy'
        ]
    }
}

// Execution profiles
profiles {
    docker {
        docker.enabled = true
        docker.runOptions = '-u $(id -u):$(id -g) -v /mnt/storage2/upgrade/nextflow/kraken2_db:/kraken2_db:ro'
        docker.sudo = true
        
        process {
            withName: 'NANOPLOT' {
                container = 'quay.io/biocontainers/nanoplot:1.42.0--pyhdfd78af_0'
            }
            withName: 'FILTLONG' {
                container = 'staphb/filtlong:0.2.1'
            }
            withName: 'FLYE' {
                container = 'staphb/flye:2.9.2'
            }
            withName: 'METABAT2' {
                container = 'metabat/metabat:v2.17-66-ga512006'
            }
            withName: 'CONCOCT' {
                container = 'quay.io/biocontainers/concoct:1.1.0--py27h88e4a8a_0'
            }
            withName: 'CHECKM.*' {
                container = 'quay.io/biocontainers/checkm-genome:1.2.2--pyhdfd78af_1'
            }
            withName: 'KRAKEN2.*' {
                container = 'staphb/kraken2:2.1.2-no-db'
            }
            withName: 'BRACKEN.*' {
                container = 'staphb/bracken:latest'
            }
        }
    }
}

// Reporting
timeline {
    enabled = true
    file = "${params.outdir}/timeline.html"
    overwrite = true
}

report {
    enabled = true
    file = "${params.outdir}/report.html"
    overwrite = true
}

trace {
    enabled = true
    file = "${params.outdir}/trace.txt"
    overwrite = true  // Suprascrie pentru început curat (mai ales pentru bracken_only mode)
    fields = 'task_id,hash,native_id,process,tag,name,status,exit,module,container,cpus,time,disk,memory,attempt,submit,start,complete,duration,realtime,queue,%cpu,%mem,rss,vmem,peak_rss,peak_vmem,rchar,wchar,syscr,syscw,read_bytes,write_bytes'
}

// Workflow configuration for continuous operation
workflow {
    // Continue workflow execution AND logging even during retries
    errorStrategy = 'retry'
    // Nu se oprește .nextflow.log când Kraken2 încearcă din nou
}