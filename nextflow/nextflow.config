// nextflow.config

params {
    // Input/Output
    input_dir = "/home/nicolaedrabcinski/upgrade/data/SRR29757947/raw"
    outdir = "results"
    
    // Resources
    threads = 60
    memory = '120.GB'
    
    // Filtlong parameters - RELAXED for small test samples
    filtlong_min_length = 200  // Reduced from 1000 for small samples
    filtlong_keep_percent = 90
    filtlong_min_quality = 7   // Reduced from 10 for small samples
    
    // Flye parameters
    flye_mode = '--nano-raw'  // Options: --nano-raw, --nano-hq, --nano-corr, --pacbio-raw, --pacbio-hifi, --pacbio-corr
    flye_genome_size = '5m'   // Estimated genome size (e.g., 5m for 5MB, 2.6g for 2.6GB) - matches your data
    flye_iterations = 1       // Reduced from 2 for faster processing
    flye_meta = true          // Enable metagenome mode for mixed microbial communities

    // Contig filtering parameters
    contig_min_length = 1500  // MetaBAT2 requires >=1500bp (hardcoded)
    
    // MetaBAT2 parameters
    metabat2_min_contig = 1500      // Minimum contig length for binning (MetaBAT2 hardcoded requirement)
    metabat2_min_bin = 200000       // Minimum bin size
    
    // CONCOCT parameters
    concoct_min_contig = 1000       // Minimum contig length for binning
    concoct_chunk_size = 5000       // Chunk size for cutting contigs
    concoct_overlap_size = 0        // Overlap size for chunks
    
    // CheckM parameters
    checkm_extension = 'fa'         // File extension for bin files
    checkm_mode = 'lineage_wf'      // Mode: 'lineage_wf' (comprehensive, reliable) - taxonomy_wf requires marker files
    checkm_domain = 'bacteria'      // Domain: 'bacteria' or 'archaea' (for taxonomy_wf mode)
    checkm_reduced_tree = false     // Not applicable for taxonomy_wf
    checkm_pplacer_threads = null   // Pplacer threads (null = auto, uses threads/2)
    
    // Bin quality filtering parameters
    skip_bin_quality_filter = false // Skip quality filtering (pass all bins)
    bin_filter_completeness = 20    // Minimum completeness threshold (%) (reduced)
    bin_filter_contamination = 20   // Maximum contamination threshold (%) (increased)
    
    // dRep dereplication parameters
    drep_ani = 0.95                 // ANI threshold for species clusters (0.95 = 95% ANI)
    drep_completeness = 50          // Minimum completeness for dRep (%)
    drep_contamination = 10         // Maximum contamination for dRep (%)
    drep_length_weight = 0          // Weight for genome length in scoring (0-1)
    drep_n50_weight = 0.5           // Weight for N50 in scoring (0-1)
    drep_completeness_weight = 1    // Weight for completeness in scoring
    drep_contamination_weight = 5   // Weight for contamination penalty
    drep_strain_heterogeneity_weight = 1  // Weight for strain heterogeneity
    
    // GTDB-Tk parameters
    gtdbtk_db = null                // Path to GTDB-Tk database (null = skip GTDB-Tk)
    gtdbtk_extension = 'fa'         // File extension for genome files
    gtdbtk_min_perc_aa = 10         // Minimum percent alignment for classification
    gtdbtk_pplacer_cpus = null      // Number of CPUs for pplacer (null = auto: threads/2)
    
    // Medaka polishing parameters (ONT-specific)
    medaka_model = 'r941_min_hac_g507'  // Model for Medaka v2.0 (r941_min_hac_g507, r941_min_sup_g507, r1041_e82_400bps_hac_v5.0.0, etc.)
    run_medaka = true                     // Enable Medaka polishing after assembly
    
    // VirSorter2 parameters (viral detection)
    virsorter2_db = null                 // Path to VirSorter2 database (null = skip viral detection)
    virsorter2_min_length = 5000         // Minimum contig length (5 KB)
    virsorter2_min_score = 0.5           // Minimum score threshold (0-1)
    run_virsorter2 = false               // Enable viral sequence detection (requires database)
    
    // PlasmidFinder parameters
    plasmidfinder_db = null              // Path to PlasmidFinder database (null = skip plasmid detection)
    plasmidfinder_min_identity = 95      // Minimum % identity
    plasmidfinder_min_coverage = 60      // Minimum % coverage
    run_plasmidfinder = false            // Enable plasmid detection (requires database)
    
    // MOB-suite parameters (plasmid reconstruction)
    run_mobsuite = false                 // Enable MOB-suite plasmid reconstruction
    
    // Kraken2 parameters
    kraken2_db = '/kraken2_db'  // Mounted from host ./data/kraken2_db
    kraken2_confidence = 0.1         // Confidence score threshold
    
    // Bracken parameters
    bracken_db = '/kraken2_db'  // Same as Kraken2 (Bracken uses same DB)
    bracken_read_len = 1000         // Read length for Bracken (1000 for ONT long reads)
    bracken_level = 'S'             // Taxonomic level (D,P,C,O,F,G,S)
    bracken_threshold = 1           // Minimum reads for classification (reduced)
    
    // Abricate parameters
    abricate_min_identity = 75      // Minimum % identity
    abricate_min_coverage = 50      // Minimum % coverage
    abricate_databases = 'card,ncbi,resfinder,argannot' // Comma-separated
    

    // Prokka parameters
    prokka_kingdom = 'Bacteria'     // Kingdom: Bacteria, Archaea, Viruses
    prokka_genus = null             // Genus for annotation (optional)
    prokka_species = null           // Species for annotation (optional)
    
    // Nucmer parameters
    nucmer_maxgap = 90              // Maximum gap between matches
    nucmer_mincluster = 65          // Minimum cluster size
    nucmer_minmatch = 20            // Minimum match length
    nucmer_min_identity = 90        // Minimum % identity for filtering
    nucmer_snps = false             // Generate SNPs file
    nucmer_reference = null         // Reference genome for HGT detection
    
    // QUAST parameters
    quast_reference = null          // Reference genome (optional)
    quast_min_contig = 500          // Minimum contig length
    
    // FastANI parameters
    fastani_fraglen = 3000          // Fragment length
    fastani_minfraction = 0.2       // Minimum fraction of genome
    
    // Roary parameters
    roary_min_identity = 95         // Minimum % identity for clustering
    roary_core_definition = 99      // % of isolates for core gene
    
    // Panaroo parameters
    panaroo_clean_mode = 'strict'   // strict, moderate, sensitive
    panaroo_threshold = 0.98        // Clustering threshold
    panaroo_core_threshold = 0.95   // Core gene threshold
    
    // Pipeline control flags
    run_amr_detection = true        // Run Abricate + DeepARG
    run_annotation = true           // Run Prokka
    run_hgt_detection = false       // Run Nucmer HGT detection
    run_comparative = false         // Run comparative genomics
    fastani_enabled = false         // Calculate ANI between samples
    roary_enabled = false           // Run pangenome analysis
    
    // Help parameter
    help = false
}

// Executor configuration — max hardware allocation (64 CPUs, 125 GB host)
executor {
    name = 'local'
    cpus = 62              // 64 CPUs - 2 reserved for OS
    memory = '120 GB'      // 125 GB - 5 GB reserved for OS
    queueSize = 16         // Increased for parallel process scheduling
}

// Process configuration
process {
    // Default settings
    cpus = { params.threads }
    time = '50h'
    
    // P1 FIX: Add error handling strategy
    // Retry on memory errors (137 = OOM killed, 140 = SIGTERM)
    // 'finish' allows other processes to complete before stopping
    errorStrategy = { task.exitStatus in [137, 140, 143, 104, 134, 139] ? 'retry' : 'finish' }
    maxRetries = 2
    
    // Dynamic memory allocation on retry (capped at executor ceiling)
    // NOTE: params.memory is a String so we parse it to an int before calling toGiga()
    memory = { task.attempt == 1 ? params.memory : "${Math.min((int)(params.memory.replace(' GB','').replace('GB','').trim().toInteger() * Math.pow(1.5, task.attempt - 1)), 120)}.GB" }

    // OPTIMIZED: Enable process caching - skip identical inputs on re-runs
    // Benefit: Re-running failed pipeline skips completed steps (saves hours)
    // 'lenient' mode: Cache based on inputs, ignore file timestamps
    cache = 'lenient'

    // Enable process parallelization — maximum CPU utilization
    maxForks = 50          // OPTIMIZED: Increased to 50 for 62-core system (allows parallel sample processing)
    executor = 'local'

    // NanoPlot process - single-threaded, low resource requirements
    withName: 'NANOPLOT' {
        cpus = 4               // Uses ~1 CPU in practice; headroom for parallel reads
        memory = '8.GB'
        time = '6h'
        publishDir = [
            path: "${params.outdir}/01_QC/nanoplot",
            mode: 'copy'
        ]
    }
    
    // Filtlong process - moderate parallelization
    withName: 'FILTLONG' {
        cpus = 32              // More CPUs reduce wall-clock time on large datasets
        memory = '16.GB'
        time = '4h'
        publishDir = [
            path: "${params.outdir}/02_filtered",
            mode: 'copy'
        ]
    }
    
    // Flye assembly process - highly parallelizable
    withName: 'FLYE' {
        maxForks = 1
        cpus = 60              // Maximum CPUs (sequential execution)
        memory = { Math.min(100 * task.attempt, 120).GB }  // Capped at 120 GB system limit
        maxRetries = 2         // 2 retries max (100→120 GB)
        // 'ignore' so assembly failure (e.g. too few reads) does not kill the whole pipeline.
        // Downstream steps (Kraken2, QC) will still run and produce taxonomy/quality results.
        errorStrategy = { task.exitStatus in [137, 140] ? 'retry' : 'ignore' }
        time = '12h'
        publishDir = [
            path: "${params.outdir}/03_assembly",
            mode: 'copy'
        ]
    }

    // Filter contigs process - lightweight
    withName: 'FILTER_CONTIGS' {
        cpus = 4
        memory = '8.GB'
        time = '1h'
        publishDir = [
            path: "${params.outdir}/03_assembly",
            mode: 'copy'
        ]
    }
    
    // MetaBAT2 binning process - moderate parallelization
    withName: 'METABAT2' {
        cpus = 32
        memory = '32.GB'
        time = '6h'
        publishDir = [
            path: "${params.outdir}/04_binning/metabat2",
            mode: 'copy'
        ]
    }
    
    // dRep dereplication - fails when no bins pass CheckM quality filters, non-fatal
    withName: 'DREP' {
        errorStrategy = 'ignore'
        cpus = 32
        memory = '32.GB'
        time = '4h'
    }

    // CONCOCT binning process - low parallelization
    // errorStrategy 'finish': CONCOCT is secondary binner, failure should not kill pipeline
    withName: 'CONCOCT' {
        errorStrategy = 'finish'
        cpus = 24
        memory = '16.GB'
        time = '8h'
        publishDir = [
            path: "${params.outdir}/04_binning/concoct",
            mode: 'copy'
        ]
    }
    
    // CheckM quality assessment process - supports multi-threading
    withName: 'CHECKM.*' {
        cpus = 16              // CheckM -t flag supports multi-threading (pplacer uses threads/2)
        memory = '32.GB'       // Increased for parallel processing
        time = '6h'            // Extended time for comprehensive analysis
        publishDir = [
            path: "${params.outdir}/05_quality",
            mode: 'copy'
        ]
    }
    
    // Kraken2 taxonomic classification - scales very well with CPU
    withName: 'KRAKEN2' {
        cpus = 48              // Taxonomic classification parallelizes extremely well
        memory = '100.GB'      // High RAM requirement for database loading
        time = '6h'
        publishDir = [
            path: "${params.outdir}/06_taxonomy",
            mode: 'copy'
        ]
    }
    
    // Bracken abundance estimation
    withName: 'BRACKEN' {
        cpus = 8
        memory = '16.GB'
        time = '2h'
        publishDir = [
            path: "${params.outdir}/07_abundance",
            mode: 'copy'
        ]
    }
    
    // Minimap2 mapping - scales well with CPU
    withName: 'MINIMAP2_MAPPING' {
        cpus = 56
        memory = '32.GB'
        time = '4h'
        errorStrategy = { task.exitStatus in [137, 139, 140] ? 'retry' : 'ignore' }
        maxRetries = 1
    }
    // Medaka polishing - ONT-specific, parallelizes well
    withName: 'MEDAKA' {
        cpus = 48
        memory = '32.GB'
        time = '8h'
        errorStrategy = 'ignore'  // No assembly → no polishing, non-fatal
        publishDir = [
            path: "${params.outdir}/03_assembly/polished",
            mode: 'copy'
        ]
    }
    
    // VirSorter2 - viral detection, parallelizable
    withName: 'VIRSORTER2' {
        cpus = 32
        memory = '64.GB'       // High RAM requirement for database loading
        time = '6h'
        publishDir = [
            path: "${params.outdir}/08_viruses",
            mode: 'copy'
        ]
    }
    
    // PlasmidFinder - fast, low resource requirements
    withName: 'PLASMIDFINDER' {
        cpus = 4
        memory = '8.GB'
        time = '2h'
        publishDir = [
            path: "${params.outdir}/09_plasmids/plasmidfinder",
            mode: 'copy'
        ]
    }
    
    // MOB-suite - plasmid reconstruction
    withName: 'MOBSUITE' {
        cpus = 16
        memory = '16.GB'
        time = '4h'
        publishDir = [
            path: "${params.outdir}/09_plasmids/mobsuite",
            mode: 'copy'
        ]
    }
    // PROKKA annotation - OPTIMIZED: scales well to ~16 CPUs, diminishing returns beyond
    withName: 'PROKKA' {
        cpus = { Math.min(16, params.threads) }
        memory = { 8.GB * task.attempt }
        time = '4h'
        maxRetries = 2
        errorStrategy = { task.exitStatus in [137, 140] ? 'retry' : 'ignore' }  // Bad bin → skip, don't kill pipeline
    }

    // ABRICATE - OPTIMIZED: single-threaded, minimal resource allocation
    withName: 'ABRICATE' {
        cpus = 1               // Single-threaded - don't waste CPUs
        memory = { 2.GB * task.attempt }  // Dynamic: retry with more RAM
        time = '2h'
        maxRetries = 2
    }
    
    // DEEPARG - moderate parallelization (legacy - per-bin processing)
    withName: 'DEEPARG' {
        cpus = 32
        memory = '16.GB'
        time = '4h'
    }

    // DEEPARG_BATCH - OPTIMIZED batch processing for multiple bins
    // Processes all bins from same sample together (saves 45-60 min per 100 bins)
    withName: 'DEEPARG_BATCH' {
        cpus = 32              // Same as DEEPARG
        memory = '20.GB'       // Slightly more RAM for batch processing
        time = '8h'            // More time for processing multiple bins
    }
    
    // ASSEMBLY_STATS - trivial process
    withName: 'ASSEMBLY_STATS' {
        cpus = 2
        memory = '2.GB'
        time = '30m'
    }
    
    // GUNZIP - simple decompression
    withName: 'GUNZIP' {
        cpus = 4
        memory = '4.GB'
        time = '1h'
    }
}

// Execution profiles
profiles {
    docker {
        docker.enabled = true
        // FIXED: Use environment variable UPGRADE_BASE_DIR instead of hardcoded path
        // This allows the pipeline to be portable across different systems
        // Default fallback uses projectDir parent directory
        // Mount host paths directly for Docker-in-Docker compatibility (RQ worker runs Nextflow in container)
        // Run containers as current user UID/GID so files belong to correct user
        docker.runOptions = { 
            def baseDir = System.getenv('UPGRADE_BASE_DIR') ?: new File("${projectDir}").getParent()
            def uid = System.getenv('DOCKER_UID') ?: '1003'
            def gid = System.getenv('DOCKER_GID') ?: '1003'
            return "-u ${uid}:${gid} -v /tmp:/tmp -v ${baseDir}/data:/data -v ${baseDir}/results:/results -v ${baseDir}/nextflow:/nextflow:ro -v ${baseDir}/data/kraken2_db:/kraken2_db:ro"
        }()
        
        // Copy files instead of symlinks for Docker-in-Docker (symlinks don't work across container boundaries)
        process.stageInMode = 'copy'

        // OPTIMIZED: Use /tmp (RAM disk or fast SSD) for scratch to reduce I/O
        // This speeds up file staging operations by 2-3x
        process.scratch = '/tmp'
        
        process {
            withName: 'NANOPLOT' {
                container = 'quay.io/biocontainers/nanoplot:1.42.0--pyhdfd78af_0'
            }
            withName: 'FILTLONG' {
                container = 'staphb/filtlong:0.2.1'
            }
            withName: 'FLYE' {
                container = 'staphb/flye:2.9.2'
            }
            withName: 'FILTER_CONTIGS' {
                container = 'quay.io/biocontainers/seqkit:2.12.0--he881be0_1'
            }
            withName: 'PROKKA' {
                container = 'staphb/prokka:1.14.6'
                stageInMode = 'copy'
            }
            withName: 'METABAT2' {
                container = 'quay.io/biocontainers/metabat2:2.18--h6f16272_0'
            }
            withName: 'CONCOCT' {
                container = 'quay.io/biocontainers/concoct:1.1.0--py27h88e4a8a_0'
            }
            withName: 'CHECKM.*' {
                container = 'quay.io/biocontainers/checkm-genome:1.2.2--pyhdfd78af_1'
            }
            withName: 'BIN_FILTER.*' {
                container = 'python:3.9'  // Use full image (not slim) - includes procps for Nextflow metrics
                stageInMode = 'copy'
            }
            withName: 'KRAKEN2' {
                container = 'staphb/kraken2:2.1.2-no-db'
            }
            withName: 'BRACKEN' {
                container = 'staphb/bracken:2.9'
            }
            withName: 'MINIMAP2_MAPPING' {
                container = 'quay.io/biocontainers/mulled-v2-66534bcbb7031a148b13e2ad42583020b9cd25c4:e1ea28074233d7265a5dc2111d6e55130dff5653-2'
            }
            withName: 'MEDAKA' {
                container = 'ontresearch/medaka:latest'
            }
            withName: 'MEDAKA_STATS' {
                container = 'ubuntu:22.04'
            }
            withName: 'VIRSORTER2' {
                container = 'jiarong/virsorter:latest'
            }
            withName: 'VIRSORTER2_SUMMARY' {
                container = 'quay.io/biocontainers/python:3.9'
            }
            withName: 'PLASMIDFINDER' {
                container = 'staphb/plasmidfinder:2.1.6'
            }
            withName: 'MOBSUITE' {
                container = 'kbessonov/mob_suite:3.0.3'
            }
            withName: 'PLASMID_SUMMARY' {
                container = 'quay.io/biocontainers/python:3.9'
            }
            withName: 'ASSEMBLY_STATS' {
                container = 'quay.io/biocontainers/biopython:1.78'
            }
            withName: 'GUNZIP' {
                container = 'ubuntu:22.04'
            }
        }
    }
}

// Reporting
timeline {
    enabled = true
    file = "${params.outdir}/nextflow_timeline.html"
    overwrite = true
}

report {
    enabled = true
    file = "${params.outdir}/nextflow_report.html"
    overwrite = true
}

trace {
    enabled = true
    file = "${params.outdir}/nextflow_trace.txt"
    overwrite = true
    fields = 'task_id,hash,native_id,process,tag,name,status,exit,module,container,cpus,time,disk,memory,attempt,submit,start,complete,duration,realtime,queue,%cpu,%mem,rss,vmem,peak_rss,peak_vmem,rchar,wchar,syscr,syscw,read_bytes,write_bytes,vol_ctxt,inv_ctxt,workdir,scratch,error_action'
}

