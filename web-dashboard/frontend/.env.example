# Environment variables for React app
# Copy this file to .env for development

# API URL - leave empty for production (uses nginx proxy)
# Set to http://localhost:8000 for local development without nginx
REACT_APP_API_URL=

# Environment
REACT_APP_ENV=development

# Feature flags
REACT_APP_ENABLE_WEBSOCKET=false
REACT_APP_ENABLE_MOCK_DATA=false

# Analytics (optional)
REACT_APP_ANALYTICS_ID=
