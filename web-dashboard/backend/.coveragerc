# Coverage configuration for UPGRADE project

[run]
source = .
omit =
    tests/*
    */__pycache__/*
    */venv/*
    */env/*
    setup.py
    conftest.py

[report]
precision = 2
show_missing = True
skip_covered = False

exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    @abstractmethod

[html]
directory = htmlcov

[xml]
output = coverage.xml
