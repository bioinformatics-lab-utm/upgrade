# ===========================================
# UPGRADE — Environment Configuration Template
# Copy to .env and fill in real values.
# NEVER commit .env to git.
# ===========================================

COMPOSE_PROJECT_NAME=upgrade
DOCKER_BUILDKIT=1

# --- Database ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=upgrade_db
POSTGRES_USER=upgrade
POSTGRES_PASSWORD=change_me_postgres
POSTGRES_EXTERNAL_PORT=5432

PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change_me_pgadmin
PGADMIN_EXTERNAL_PORT=5050

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis
REDIS_EXTERNAL_PORT=6379

# --- MinIO ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio
MINIO_ENDPOINT=minio:9000
MINIO_EXTERNAL_ENDPOINT=localhost:9000
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=upgrade

# --- Kafka ---
KAFKA_BROKER_ID=1
KAFKA_EXTERNAL_PORT=9092
KAFKA_ZOOKEEPER_CONNECT=zookeeper:2181
KAFKA_LISTENER_SECURITY_PROTOCOL_MAP=PLAINTEXT:PLAINTEXT,PLAINTEXT_HOST:PLAINTEXT
KAFKA_ADVERTISED_LISTENERS=PLAINTEXT://kafka:29092,PLAINTEXT_HOST://localhost:9092
KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR=1
KAFKA_AUTO_CREATE_TOPICS_ENABLE=true
KAFKA_LOG_RETENTION_HOURS=168
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
ZOOKEEPER_CLIENT_PORT=2181
ZOOKEEPER_TICK_TIME=2000
KAFKA_CLUSTERS_0_NAME=local
KAFKA_CLUSTERS_0_BOOTSTRAPSERVERS=kafka:29092
KAFKA_UI_PORT=8082

# --- Nextflow ---
NXF_HOME=/opt/nextflow/.nextflow
NXF_WORK=/data/nextflow-work
JAVA_OPTS=-Xmx4g -Xms1g
UPGRADE_BASE_DIR=/home/your_user/upgrade

# --- Logging ---
LOG_LEVEL=INFO
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_grafana
ALERT_EMAIL_TO=admin@example.com
HEALTH_CHECK_INTERVAL=30s
HEALTH_CHECK_TIMEOUT=10s
HEALTH_CHECK_RETRIES=3
HEALTH_CHECK_START_PERIOD=60s

# --- Web Dashboard ---
GEO_DASHBOARD_BACKEND_PORT=8000
GEO_DASHBOARD_FRONTEND_PORT=3000
SANIC_PORT=8000
SANIC_DEBUG=false
SANIC_AUTO_RELOAD=false
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# JWT secret: generate with: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=change_me_generate_with_secrets_token_urlsafe

# --- RQ Worker ---
RQ_DASHBOARD_PORT=9181
UPGRADE_USER_PASSWORD=change_me_user_password
